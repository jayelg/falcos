#!/usr/bin/bash
# Copies the image-staged Affinity DLLs and WinRT metadata into this user's
# Wine prefix, so image updates (Wine/DXVK/vkd3d bumps) reach existing
# prefixes. Called by affinity-sync.service at login and by
# `falcos affinity-setup`. DllOverrides persist in the prefix registry and
# need no refresh. DXVK's dxgi + vkd3d-proton's d3d12 is the standard
# pairing; Affinity loads d3d12 and the wintypes shim from its own
# directory.
set -euo pipefail

prefix="${AFFINITY_PREFIX:-$HOME/.local/share/affinity}"
sys32="$prefix/drive_c/windows/system32"
[ -d "$sys32" ] || exit 0

install -m 0644 /usr/share/wine-affinity/dxvk/x64/{d3d9,d3d10core,d3d11,dxgi}.dll "$sys32/"
install -m 0644 /usr/share/wine-affinity/vkd3d-proton/x64/{d3d12,d3d12core}.dll "$sys32/"
install -D -m 0644 /usr/share/wine-affinity/WinMetadata/Windows.winmd \
    "$sys32/WinMetadata/Windows.winmd"

appdir="$prefix/drive_c/Program Files/Affinity/Affinity"
if [ -d "$appdir" ]; then
    install -m 0644 /usr/share/wine-affinity/vkd3d-proton/x64/{d3d12,d3d12core}.dll "$appdir/"
    install -m 0644 /usr/share/wine-affinity/wintypes.dll "$appdir/"
fi
