#!/usr/bin/bash
# Emits an OSC 9;4 progress signal that the falcos TUI reads to drive its
# bottom progress bar. Also understood by Windows Terminal, ConEmu and
# systemd's PTY forwarder, and silently ignored by plain terminals.
#
#   falcos-progress <percent 0-100>   set the bar
#   falcos-progress clear             remove the bar
#
# Recipes call this on stdout while running under the TUI's pane.
case "${1:-}" in
    clear | "")
        printf '\033]9;4;0;\007'
        ;;
    *)
        printf '\033]9;4;1;%s\007' "$1"
        ;;
esac
