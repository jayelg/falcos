# =============================================================================
# Falcos Component Inventory — source of truth for what goes in the image.
#
# Order matters: each line becomes one Containerfile RUN layer, in this
# order. Keep heavy, rarely-changing components early for better layer
# caching, and flavor-gated components last, next to the flavor split.
#
# Editing this file is all that's needed: `just build` and the CI build
# generate Containerfile.generated (skeleton Containerfile + one RUN
# layer per line here) automatically before building. The committed
# Containerfile stays an empty skeleton; nothing generated is committed.
#
# Syntax:
#   <name>            enable the component at build_files/components/**/<name>
#   <name>@<variant>  enable it with its variants/<variant>.sh overrides
#   # <name>          comment out to disable
#
# [flavor] sections gate components to a single flavor. Everything above
# the first [flavor] header builds on all flavors. Flavor sections must
# stay at the bottom to preserve the cache fork.
#
# Version pins live in each component's versions.sh (Renovate-tracked),
# not here. A component that needs extra mounts or env (build secrets,
# ARGs) ships its own Containerfile.part; see cachyos-kernel, gaming and
# looking-glass.
# =============================================================================

# Base + essential falcos framework. Lead the list: the minimal set that
# makes a buildable image carry this repo's own tooling. base is a pure-file
# system layer (sshd-off preset, coredump/PAM lockdown, branding);
# auto-updates is the self-update + signing mechanism; falcos-tools is the
# falcos-cli OS TUI + `just` recipe engine (KDE-independent, so it leads).
base
auto-updates
falcos-tools

# Core system (build_files/components/core/) -- do not disable
flatpak
brew
cli-tools
cli-customizations
manage-dotfiles

# Kernel (build_files/components/kernel/). The KERNEL=stock build arg
# (ARG in the Containerfile, flipped by kernel-freshness.yml) keeps the
# Fedora base kernel instead.
cachyos-kernel

# Security & hardening (build_files/components/{security,hardening}/)
security
hardened-malloc
sudo-hardening

# Hardware support (build_files/components/hardware/)
firmware
gaming
hardware-tools

# Desktop environment (build_files/components/de/)
kde-desktop
kde-theming
bazaar

# Multimedia & networking
multimedia
networking

# Dev tools (build_files/components/core/)
dev-tools

# Virtualization (build_files/components/virtualization/)
libvirt
incus
podman

# VPN (build_files/components/vpn/)
mullvad-vpn
netbird
tailscale

# Desktop applications (build_files/components/apps/)
affinity
trivalent
vscodium
bitwarden

# Kept last: frequently-bumped components, so their rebuilds stay at the
# bottom of the layer stack. falcos-plasma-settings also lands here since it
# must follow kde-desktop (it installs a Plasma/KCM module from an RPM).
plasma-network-audio
falcos-plasma-settings

# ---------------------------------------------------------------------------
# Flavor-gated components. The generator injects COMPONENT_FLAVORS=<flavor>
# for components under a [flavor] header so run-component.sh skips them on
# other flavors. Components with a Containerfile.part (looking-glass) gate
# themselves; the generator cross-checks the part's COMPONENT_FLAVORS
# matches the section header and errors on mismatch.
# ---------------------------------------------------------------------------

[desktop]
vfio-passthrough
looking-glass

[laptop]
laptop-tweaks
