#!/usr/bin/bash
set -euo pipefail

# Installer pinned to a commit and checksum rather than curl|bash from
# HEAD, so a compromised Homebrew repo or CDN response can't execute
# arbitrary code at first login. Homebrew/install publishes no tags or
# checksums, so bump the pair together manually:
#   curl -fsSL https://raw.githubusercontent.com/Homebrew/install/<commit>/install.sh | sha256sum
INSTALLER_COMMIT="4b0227cf8416504142d23893368c2e1d211d5191"
INSTALLER_SHA256="99287f194a8b3c9e6b0203a11a5fa54518be57209343e6bb954dec4635796d9d"

installer="$(mktemp)"
trap 'rm -f "$installer"' EXIT

curl -fsSL --retry 3 \
    "https://raw.githubusercontent.com/Homebrew/install/${INSTALLER_COMMIT}/install.sh" \
    -o "$installer"
echo "${INSTALLER_SHA256}  ${installer}" | sha256sum -c -

NONINTERACTIVE=1 /bin/bash "$installer"
