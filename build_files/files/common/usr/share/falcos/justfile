# vim: set ft=make :
# System justfile behind the os-name alias (etc/profile.d/falcos-cli.sh).
# Ships in the image so recipes are always current; personal additions go
# in ~/.config/just/user.justfile via the import at the bottom.
# Comments above recipes provide the description for falcos-cli.
set allow-duplicate-recipes := true
set ignore-comments := true

_default:
    @just --justfile '{{ justfile() }}' --list --list-heading $'Available commands:\n' --list-prefix $' - '

# Update system and flatpaks
[group('System')]
update:
    #!/usr/bin/bash
    # falcos-progress feeds the TUI's bottom bar; a no-op in a plain terminal.
    # Steps are coarse (bootc/flatpak don't report percentages). `:` fallback
    # keeps the recipe runnable where the helper isn't installed.
    prog=/usr/libexec/falcos-progress
    [ -x "$prog" ] || prog=:
    SERVICE="bootc-fetch-apply-updates.service"
    if systemctl is-active --quiet "$SERVICE"; then
        echo "Automatic updates are currently running, use \`journalctl -fexu $SERVICE\` to see logs"
        exit 1
    fi
    echo "==> Updating system image..."
    "$prog" 10
    # bootc upgrade doesn't support local layered packages, so fall back to
    # rpm-ostree upgrade if LockLayering is off in /etc/rpm-ostreed.conf.
    if command -v rpm-ostree >/dev/null 2>&1 && [ -f /etc/rpm-ostreed.conf ] && \
        grep -qE '^[[:space:]]*LockLayering[[:space:]]*=[[:space:]]*true' /etc/rpm-ostreed.conf; then
        sudo bootc upgrade
    else
        rpm-ostree upgrade
    fi
    echo "==> Updating flatpaks..."
    "$prog" 60
    if flatpak remotes | grep -q system; then
        flatpak update -y
    fi
    if flatpak remotes | grep -q user; then
        flatpak update --user -y
    fi
    "$prog" 100
    "$prog" clear
    echo "Done."

# Show BIOS info
[group('System')]
bios-info:
    #!/usr/bin/bash
    sudo bash <<'EOF'
    echo "Manufacturer: $(dmidecode -s baseboard-manufacturer)"
    echo "Product Name: $(dmidecode -s baseboard-product-name)"
    echo "Version: $(dmidecode -s bios-version)"
    echo "Release Date: $(dmidecode -s bios-release-date)"
    EOF

# Measure idle power draw
[group('System')]
check-idle-power-draw:
    #!/usr/bin/bash
    sudo powerstat -a -r

# Regenerate grub.cfg with os-prober so other installed OSes (e.g. Windows) show up in the boot menu
[group('System')]
regenerate-grub:
    sudo /usr/libexec/grub2-os-prober-regen

# Set up dotfiles and secrets with chezmoi and Vaultwarden — run once on a new machine
[group('Configuration')]
setup-dotfiles:
    #!/usr/bin/env bash
    set -eou pipefail

    echo "==> Configuring Bitwarden CLI..."
    BW_STATUS=$(bw status 2>/dev/null | jq -r '.status' 2>/dev/null || echo "unauthenticated")
    if [[ "$BW_STATUS" == "unauthenticated" ]]; then
        read -rp "Vaultwarden server URL: " BW_SERVER
        bw config server "$BW_SERVER"
    else
        echo "Already authenticated — skipping server config."
    fi

    echo ""
    echo "==> Unlocking Bitwarden vault..."
    BW_STATUS=$(bw status 2>/dev/null | jq -r '.status' 2>/dev/null || echo "unauthenticated")
    if [[ "$BW_STATUS" == "unauthenticated" ]]; then
        BW_SESSION=$(bw login --raw)
    else
        BW_SESSION=$(bw unlock --raw)
    fi
    export BW_SESSION

    echo ""
    echo "==> Checking SSH key for GitHub..."
    # Named distinctly from ~/.ssh/id_ed25519 (which the dotfiles repo itself
    # manages as a separate, shared identity) so this per-device bootstrap
    # key is never overwritten by `chezmoi apply` below, and each device gets
    # its own key to register/revoke independently on GitHub.
    SSH_KEY="${HOME}/.ssh/id_ed25519_github"
    if [[ ! -f "$SSH_KEY" ]]; then
        echo "No SSH key found. Generating one..."
        ssh-keygen -t ed25519 -C "$(hostname)-$(git config user.email 2>/dev/null || echo '')" -N "" -f "$SSH_KEY"
    fi

    # GIT_SSH_COMMAND below only covers this script's own `chezmoi init`
    # call — later, independent commands (`chezmoi re-add`, `chezmoi update`,
    # plain `git` in a fresh shell) don't inherit it, and would otherwise
    # fall back to SSH's default key-trial order. Pinning github.com to this
    # key in ~/.ssh/config makes every future session use it too.
    SSH_CONFIG="${HOME}/.ssh/config"
    mkdir -p "${HOME}/.ssh"
    touch "$SSH_CONFIG"
    chmod 600 "$SSH_CONFIG"
    if ! grep -qF "IdentityFile ${SSH_KEY}" "$SSH_CONFIG"; then
        printf '\nHost github.com\n    IdentityFile %s\n    IdentitiesOnly yes\n' "$SSH_KEY" >> "$SSH_CONFIG"
    fi

    export GIT_SSH_COMMAND="ssh -i ${SSH_KEY} -o IdentitiesOnly=yes"

    SSH_RESULT=$(ssh -i "$SSH_KEY" -o IdentitiesOnly=yes -o BatchMode=yes -o ConnectTimeout=5 -T git@github.com 2>&1 || true)
    if ! echo "$SSH_RESULT" | grep -q "successfully authenticated"; then
        echo ""
        echo "SSH key is not yet registered on GitHub. Add this public key at:"
        echo "  https://github.com/settings/ssh/new"
        echo ""
        cat "${SSH_KEY}.pub"
        echo ""
        read -rp "Press Enter once you've added the key to GitHub..."

        SSH_RESULT=$(ssh -i "$SSH_KEY" -o IdentitiesOnly=yes -o BatchMode=yes -o ConnectTimeout=5 -T git@github.com 2>&1 || true)
        if ! echo "$SSH_RESULT" | grep -q "successfully authenticated"; then
            echo "Error: SSH authentication to GitHub still failing. Check that the key was added correctly."
            exit 1
        fi
    fi
    echo "GitHub SSH authentication confirmed."

    echo ""
    echo "==> Applying dotfiles..."
    chezmoi init --apply git@github.com:johngrantdev/dotfiles.git

    echo ""
    echo "Done! Dotfiles applied."
    echo "To keep the vault unlocked in your current shell, run:"
    echo "  export BW_SESSION=\$(bw unlock --raw)"

# Randomize MAC address for the current Wi-Fi connection to improve privacy on public networks
[group('Network')]
randomize-mac:
    #!/usr/bin/env bash
    set -eou pipefail

    ACTIVE=$(nmcli -t -f NAME,TYPE connection show --active | awk -F: '$2=="802-11-wireless"{print $1; exit}')
    if [[ -z "$ACTIVE" ]]; then
        echo "No active Wi-Fi connection found."
        exit 1
    fi

    echo "==> Setting MAC randomization for: $ACTIVE"
    nmcli connection modify "$ACTIVE" wifi.cloned-mac-address random
    nmcli connection down "$ACTIVE"
    nmcli connection up "$ACTIVE"
    echo "Done. New MAC: $(ip link show wlan0 | awk '/ether/{print $2}')"

# Set up the Affinity v3 Wine prefix for this user (Wine and DLLs ship in the image; run once)
[group('Apps')]
affinity-setup:
    #!/usr/bin/env bash
    set -eou pipefail

    export WINEPREFIX="$HOME/.local/share/affinity"
    export WINE=/usr/lib/wine-affinity/bin/wine
    export WINESERVER=/usr/lib/wine-affinity/bin/wineserver
    export PATH="/usr/lib/wine-affinity/bin:$PATH"
    # Wine crashes under the system-wide hardened_malloc preload
    unset LD_PRELOAD

    echo "==> Initialising Wine prefix at $WINEPREFIX..."
    wineboot --init

    # Component set and order from upstream Linux-Affinity-Installer
    echo "==> Installing Windows components via winetricks (slow, downloads ~1 GB)..."
    winetricks --unattended --force remove_mono vcrun2022 dotnet48 corefonts win11 tahoma renderer=vulkan
    winecfg -v win11

    echo "==> Installing DLLs + WinRT metadata from the image..."
    /usr/libexec/affinity-sync-prefix

    # wintypes native so Affinity loads the shim staged next to its exe
    # instead of Wine's builtin
    for dll in d3d9 d3d10core d3d11 dxgi d3d12 d3d12core wintypes; do
        "$WINE" reg add 'HKCU\Software\Wine\DllOverrides' /v "$dll" /d native /f >/dev/null
    done

    echo ""
    echo "Download the Affinity v3 installer (.exe) from https://www.affinity.studio"
    read -rp "Path to the installer .exe: " exe
    WINEDEBUG=-all "$WINE" "$exe"

    # Second sync now that the app directory exists (d3d12 + wintypes
    # shim go next to Affinity.exe)
    appdir="$WINEPREFIX/drive_c/Program Files/Affinity/Affinity"
    if [[ -d "$appdir" ]]; then
        /usr/libexec/affinity-sync-prefix
        echo "Done. Launch from the Affinity menu entry, or run: affinity"
        echo "Verify OpenCL under Settings > Performance (Hardware acceleration)."
    else
        echo "Installer finished but $appdir was not found;"
        echo "re-run 'falcos affinity-setup' after a successful install."
        exit 1
    fi

# Remove this user's Affinity Wine prefix (the image-baked Wine and launcher remain)
[group('Apps')]
affinity-remove:
    #!/usr/bin/env bash
    set -eou pipefail
    /usr/lib/wine-affinity/bin/wineserver -k 2>/dev/null || true
    rm -rf "$HOME/.local/share/affinity"
    rm -f "$HOME/.local/share/applications/wine/Programs/Affinity.desktop"
    echo "Removed ~/.local/share/affinity"

# Exempt an app from the system-wide hardened_malloc LD_PRELOAD (fixes crashes in some GTK/Electron apps)
[group('Hardening')]
hardened-malloc-exempt app:
    #!/usr/bin/env bash
    set -eou pipefail
    app="{{ app }}"

    fixed=0
    sysdesk="/usr/share/applications/${app}.desktop"
    userdesk="$HOME/.local/share/applications/${app}.desktop"

    # Menu/launcher path: for system apps, shadow the entry with an override
    # that drops LD_PRELOAD. For user-level entries (e.g. AppImages added via
    # Gear Lever) there is no system entry to shadow, so patch in place.
    if [[ -f "$sysdesk" ]]; then
        mkdir -p "$HOME/.local/share/applications"
        sed 's/^Exec=/Exec=env -u LD_PRELOAD /' "$sysdesk" > "$userdesk"
        echo "==> Wrote launcher override: $userdesk"
        fixed=1
    elif [[ -f "$userdesk" ]]; then
        if grep -q '^Exec=env -u LD_PRELOAD ' "$userdesk"; then
            echo "==> Already exempted: $userdesk"
        else
            sed -i 's/^Exec=/Exec=env -u LD_PRELOAD /' "$userdesk"
            echo "==> Patched launcher in place: $userdesk"
            echo "    App updates may rewrite this file (e.g. Gear Lever), re-run after updating."
        fi
        fixed=1
    else
        echo "No desktop entry ${app}.desktop, candidates:"
        { ls /usr/share/applications; ls "$HOME/.local/share/applications" 2>/dev/null; } | grep -i -- "$app" | sort -u || echo "  (none)"
    fi
    if [[ "$fixed" == 1 ]]; then
        update-desktop-database "$HOME/.local/share/applications" 2>/dev/null || true
        command -v kbuildsycoca6 >/dev/null && kbuildsycoca6 2>/dev/null || true
    fi

    # Terminal path: shim in ~/.local/bin, which precedes /usr/bin in PATH.
    if [[ -x "/usr/bin/${app}" ]]; then
        shim="$HOME/.local/bin/${app}"
        mkdir -p "$HOME/.local/bin"
        printf '#!/usr/bin/env bash\nexec env -u LD_PRELOAD /usr/bin/%s "$@"\n' "$app" > "$shim"
        chmod 755 "$shim"
        echo "==> Wrote CLI shim: $shim"
        fixed=1
    fi

    if [[ "$fixed" == 0 ]]; then
        echo "Nothing exempted, no desktop entry or /usr/bin binary matched '${app}'."
        exit 1
    fi
    echo "Done. Consider baking a wrapper into the image if this exemption proves permanent."

# Remove a hardened_malloc exemption created by hardened-malloc-exempt
[group('Hardening')]
hardened-malloc-unexempt app:
    #!/usr/bin/env bash
    set -eou pipefail
    app="{{ app }}"

    removed=0
    dest="$HOME/.local/share/applications/${app}.desktop"
    if [[ -f "$dest" ]] && grep -q 'env -u LD_PRELOAD' "$dest"; then
        if [[ -f "/usr/share/applications/${app}.desktop" ]]; then
            # Override copy of a system entry, remove the shadow.
            rm "$dest"
            echo "==> Removed launcher override: $dest"
        else
            # In-place patched user entry (e.g. AppImage), restore it.
            sed -i 's/^Exec=env -u LD_PRELOAD /Exec=/' "$dest"
            echo "==> Restored launcher: $dest"
        fi
        update-desktop-database "$HOME/.local/share/applications" 2>/dev/null || true
        command -v kbuildsycoca6 >/dev/null && kbuildsycoca6 2>/dev/null || true
        removed=1
    fi
    shim="$HOME/.local/bin/${app}"
    if [[ -f "$shim" ]] && grep -q 'env -u LD_PRELOAD' "$shim"; then
        rm "$shim"
        echo "==> Removed CLI shim: $shim"
        removed=1
    fi
    [[ "$removed" == 1 ]] || echo "No exemption found for '${app}'."

# List hardened_malloc exemptions (user overrides and image-baked wrappers)
[group('Hardening')]
hardened-malloc-exemptions:
    #!/usr/bin/env bash
    echo "User launcher overrides:"
    grep -l 'env -u LD_PRELOAD' "$HOME/.local/share/applications"/*.desktop 2>/dev/null || echo "  (none)"
    echo "User CLI shims:"
    grep -l 'env -u LD_PRELOAD' "$HOME/.local/bin"/* 2>/dev/null || echo "  (none)"
    echo "Baked into the image:"
    grep -rl 'env -u LD_PRELOAD' /usr/bin /usr/share/codium/codium 2>/dev/null || echo "  (none)"

# Reboot this machine
[group('Power')]
reboot:
    #!/usr/bin/bash
    if gum confirm "Reboot now?"; then
        systemctl reboot
    else
        echo "Cancelled."
    fi

# Reboot into this device's UEFI (BIOS) setup screen
[group('Power')]
reboot-uefi:
    #!/usr/bin/bash
    if [ ! -d /sys/firmware/efi ]; then
        echo "Rebooting to legacy BIOS from OS is not supported."
        exit 1
    fi
    if gum confirm "Reboot into UEFI setup?"; then
        systemctl reboot --firmware-setup
    else
        echo "Cancelled."
    fi

# Shut down this machine
[group('Power')]
shutdown:
    #!/usr/bin/bash
    if gum confirm "Shut down now?"; then
        systemctl poweroff
    else
        echo "Cancelled."
    fi

# Personal additions, not managed by the image
import? "~/.config/just/user.justfile"
