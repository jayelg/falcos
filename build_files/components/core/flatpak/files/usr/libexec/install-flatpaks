#!/usr/bin/bash
set -euo pipefail

flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

# /usr/share/falcos/default-flatpaks is an aggregate of every component's
# flatpaks.list, assembled at build time by run-component.sh. One flatpak
# ID per line; blank lines and # comments are ignored.
FLATPAK_LIST="/usr/share/falcos/default-flatpaks"
if [ -f "$FLATPAK_LIST" ]; then
    while IFS= read -r flatpak_id; do
        # skip blank lines and comments
        [[ -z "$flatpak_id" || "$flatpak_id" == \#* ]] && continue
        echo "Installing default flatpak: ${flatpak_id}"
        flatpak install --system -y --noninteractive flathub "$flatpak_id"
    done < "$FLATPAK_LIST"
fi
